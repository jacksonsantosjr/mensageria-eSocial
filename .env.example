# ============================================
# eSocial Mensageria — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.

# --- Banco de Dados (Local / Docker) ---
POSTGRES_USER=esocial
POSTGRES_PASSWORD=esocial_dev
POSTGRES_DB=esocial_mensageria
DATABASE_URL=postgresql://esocial:esocial_dev@db:5432/esocial_mensageria

# --- Banco de Dados (Supabase — Produção) ---
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Ambiente ---
# Valores: production | homologacao
ENVIRONMENT=homologacao

# --- Certificado Digital A1 ---
# Caminho para o diretório contendo os arquivos .pfx
# ATENÇÃO: Nunca commite arquivos .pfx no repositório!
CERT_PATH=/certs
CERT_PASSWORD=sua_senha_do_certificado

# --- CNPJ do Transmissor ---
# CNPJ da empresa responsável pela transmissão (14 dígitos, sem pontuação)
CNPJ_TRANSMISSOR=00000000000000

# --- CORS ---
# Origens permitidas para o frontend (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000

# --- Modo Mock (Desenvolvimento) ---
# Quando true, o SOAP client retorna respostas simuladas
MOCK_ESOCIAL=true
